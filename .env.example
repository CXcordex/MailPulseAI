# ═══════════════════════════════════════════════════════════════════════════════
# MailPulseAI — Environment Configuration (Monolith)
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to git!
# ═══════════════════════════════════════════════════════════════════════════════

# ── Primary AI (Groq — free, no credit card needed) ──────────────────────────
# Sign up: console.groq.com → API Keys → Create
# Free tier: 30 RPM, 1000 RPD with llama-3.1-8b-instant
GROQ_API_KEY=gsk_REPLACE_ME

# ── Gmail OAuth 2.0 ──────────────────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
# Run scripts/get_refresh_token.py to obtain the refresh token
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REFRESH_TOKEN=1//0g-REPLACE_ME

# ── WhatsApp / Twilio ────────────────────────────────────────────────────────
# Get from: console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
# Twilio WhatsApp sandbox number (always this format):
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# YOUR personal WhatsApp number to receive notifications:
WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# ── Database (managed by Docker Compose — override only for external DB) ─────
# When using docker-compose, these are auto-set. Only change if using an
# external PostgreSQL instance (e.g. Render managed DB, Supabase, etc.)
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/mailpulseai
# SPRING_DATASOURCE_USERNAME=mailpulseai
# SPRING_DATASOURCE_PASSWORD=mailpulseai_secret

# ── Optional Fallback AI API Keys (rotation order after primary Groq) ────────
# If set, these are tried automatically when the primary key is rate-limited.
# FALLBACK_GROQ_KEY_1=gsk_...
# FALLBACK_GROQ_KEY_2=gsk_...
# NVIDIA_API_KEY_1=nvapi-...
# NVIDIA_API_KEY_2=nvapi-...
# OPENROUTER_API_KEY=sk-or-v1-...
# GEMINI_API_KEY=AIzaSy...
